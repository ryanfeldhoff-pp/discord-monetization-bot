# Discord Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here

# Database
DATABASE_URL=sqlite+aiosqlite:///./discord_bot.db
# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/discord_bot

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# PrizePicks API
PRIZEPICKS_API_BASE=https://api.prizepicks.com
PRIZEPICKS_API_KEY=your_api_key_here

# Logging
LOG_LEVEL=INFO
LOG_FILE=bot.log

