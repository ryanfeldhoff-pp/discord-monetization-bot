# ============================================================================
# ENVIRONMENT CONFIGURATION
# ============================================================================
ENVIRONMENT=development
DEBUG=False
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# DISCORD BOT CONFIGURATION
# ============================================================================
# Bot token from Discord Developer Portal
DISCORD_BOT_TOKEN=your_bot_token_here

# Guild (server) ID
DISCORD_GUILD_ID=654321

# Role ID for "Account Linked" indicator role
DISCORD_LINKED_ROLE_ID=123456789

# Tier role IDs (assign these when users reach tier thresholds)
DISCORD_TIER_ROLE_IDS_BRONZE=111111111
DISCORD_TIER_ROLE_IDS_SILVER=222222222
DISCORD_TIER_ROLE_IDS_GOLD=333333333
DISCORD_TIER_ROLE_IDS_DIAMOND=444444444

# Alert channel IDs (comma-separated, optional)
# Bot posts board movement alerts to these channels
DISCORD_ALERT_CHANNEL_IDS=555555555,666666666

# ============================================================================
# PRIZEPICKS API CONFIGURATION
# ============================================================================
# PrizePicks API base URL
PRIZEPICKS_API_BASE_URL=https://api.prizepicks.com

# PrizePicks API key (obtained from backend team)
PRIZEPICKS_API_KEY=your_api_key_here

# API request timeout in seconds
PRIZEPICKS_API_TIMEOUT=30

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL=postgresql+asyncpg://discord:discord_password@localhost:5432/monetization_bot

# Connection pool settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# Redis connection string
# Format: redis://[password@]host:port/db
REDIS_URL=redis://localhost:6379/0

# Redis database number (0-15)
REDIS_DB=0

# ============================================================================
# XP SYSTEM CONFIGURATION
# ============================================================================
# Points awarded for different actions
XP_PER_MESSAGE=5
XP_PER_SHARE=15
XP_PER_TAIL=25
XP_PER_LINK=50

# Daily XP cap (prevent farming)
XP_DAILY_CAP=500

# Multiplier for XP earned by linked accounts
XP_LINKED_MULTIPLIER=2.0

# Decay settings (reduce XP if user inactive)
XP_DECAY_RATE=0.05
XP_DECAY_FLOOR=100
XP_DECAY_INTERVAL_DAYS=7

# ============================================================================
# TIER CONFIGURATION
# ============================================================================
# XP thresholds for each tier
TIER_BRONZE_THRESHOLD=500
TIER_SILVER_THRESHOLD=2500
TIER_GOLD_THRESHOLD=7500
TIER_DIAMOND_THRESHOLD=15000

# ============================================================================
# REDEMPTION / PROMO CATALOG
# ============================================================================
# Redemption catalog is configured in code
# See config/settings.py for customization

# ============================================================================
# ANALYTICS CONFIGURAZé·N
# ============================================================================
# Enable/disable event tracking
ANALYTICS_ENABLED=True

# Analytics provider: posthog, mixpanel, or webhook
ANALYTICS_PROVIDER=posthog

# API key for analytics provider
ANALYTICS_API_KEY=your_api_key_here

# Optional webhook endpoint for analytics
ANALYTICS_ENDPOINT=https://your-webhook.example.com/events

# How often to flush analytics events to server (seconds)
ANALYTICS_FLUSH_INTERVAL=60

# ============================================================================
# OCR CONFIGURATUON
# ============================================================================
# Enable/disable image parsing
OCR_ENABLED=True

# OCR provider: google_vision or aws_textract
OCR_PROVIDER=google_vision

# API key for OCR provider
OCR_API_KEY=your_ocr_api_key

# Confidence threshold for OCR results (0.0-1.0)
OCR_CONFIDENCE_THRESHOLD=0.8

# ============================================================================
# BOARD ALERT CONFIGURATION
# ============================================================================
# Enable/disable board monitoring
BOARD_ALERTS_ENABLED=True

# How often to poll PrizePicks API for board changes (seconds)
BOARD_ALERTS_POLL_INTERVAL=300

# Threshold for detecting "bumped" entries (5% = 0.05)
BOARD_ALERTS_BUMP_THRESHOLD=0.05

# Rate limiting: max alerts per hour
BOARD_ALERTS_MAX_PER_HOUR=10

# ============================================================================
# OAUTH CONFIGURATION
# ============================================================================
# OAuth client credentials (from PrizePicks auth provider)
OAUTH_CLIENT_ID=your_client_id
OAUTH_CLIENT_SECRET=your_client_secret

# Redirect URI after user completes OAuth flow
OAUTH_REDIRECT_URI=https://your-domain.com/oauth/callback

# OAuth scopes to request
OAUTH_SCOPES=user:read,user:email

# ============================================================================
# OPTIONAL: CUSTOM SETTINGS
# ============================================================================
# Add additional configuration as needed for your deployment
